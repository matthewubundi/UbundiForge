#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" && pwd)"
INSTALLER="$ROOT_DIR/scripts/install.sh"
VENV_DIR="${VENV_DIR:-$ROOT_DIR/.venv}"
FORGE_BIN="$VENV_DIR/bin/forge"
STAMP_FILE="$VENV_DIR/.forge-install-stamp"

needs_install=false

if [ ! -x "$FORGE_BIN" ] || [ ! -f "$STAMP_FILE" ]; then
  needs_install=true
elif [ "$ROOT_DIR/pyproject.toml" -nt "$STAMP_FILE" ]; then
  needs_install=true
elif [ "$INSTALLER" -nt "$STAMP_FILE" ]; then
  needs_install=true
fi

if [ "$needs_install" = true ]; then
  "$INSTALLER" >&2
fi

exec "$FORGE_BIN" "$@"
